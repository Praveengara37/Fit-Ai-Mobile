const validateGoals = () => {
  const calculatedCals = (protein * 4) + (carbs * 4) + (fat * 9);
  const diff = Math.abs(calculatedCals - calories);
  const percentDiff = (diff / calories) * 100;
  
  if (percentDiff > 10) {
    Alert.alert(
      'Macro Mismatch',
      `Your macros (${Math.round(calculatedCals)} cal) don't match your calorie goal (${calories} cal).`
    );
    return false;
  }
  return true;
};
