import Slider from '@react-native-community/slider';
import * as Haptics from 'expo-haptics';

export default function StepGoalsScreen() {
  const [goal, setGoal] = useState(10000);
  const [loading, setLoading] = useState(false);
  
  const handleSave = async () => {
    setLoading(true);
    try {
      await api.patch('/api/profile/update', {
        dailyStepGoal: goal
      });
      Haptics.notificationAsync(Haptics.NotificationFeedbackType.Success);
      Alert.alert('Success', 'Step goal updated!');
      router.back();
    } catch (error) {
      Alert.alert('Error', 'Failed to update goal');
    } finally {
      setLoading(false);
    }
  };
  
  return (
    <View>
      <Slider
        minimumValue={1000}
        maximumValue={50000}
        step={500}
        value={goal}
        onValueChange={setGoal}
        minimumTrackTintColor="#a855f7"
        maximumTrackTintColor="#2a2235"
      />
      <Text>{goal.toLocaleString()} steps</Text>
      <Button onPress={handleSave} loading={loading}>Save Goal</Button>
    </View>
  );
}
```

